# ── 클라이언트에 노출되는 값 (시크릿 아님) ──
NEXT_PUBLIC_GEMMA_BACKEND=proxy        # 'ollama' | 'proxy' — UI 표시용
NEXT_PUBLIC_OLLAMA_URL=http://localhost:11434
NEXT_PUBLIC_API_PROXY_URL=/api/gemma

# ── 서버 사이드 전용 (절대 NEXT_PUBLIC_ 접두사 금지) ──
GEMMA_BACKEND=proxy                    # 서버 보안 체크 전용 (클라이언트 노출 금지)
GEMMA_API_KEY=your-google-ai-studio-key
GEMMA_MODEL=gemma-4-12b-it
RATE_LIMIT_PER_MIN=10
DAILY_CALL_LIMIT=2000
